{
  "name": "@organigram/contracts",
  "version": "0.1.3",
  "description": "Solidity smart-contracts framework for governance systems.",
  "author": "Organigr.am <dev@organigr.am> (https://organigr.am)",
  "license": "LGPL-3.0-or-later",
  "scripts": {
    "build": "yarn truffle build",
    "build:abis": "docker run --rm -v $(pwd):/var/data -w /var/data ethereum/solc:stable contracts/*.sol --abi -o abis --overwrite",
    "build:bin": "docker run --rm -v $(pwd):/var/data -w /var/data ethereum/solc:stable contracts/*.sol --bin -o bin --overwrite",
    "test": "echo \"Error: no test specified\" && exit 1",
    "cleanup": "yarn truffle networks --clean"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^4.2.0"
  },
  "devDependencies": {
    "@truffle/hdwallet-provider": "^1.4.2",
    "bs58": "^4.0.1",
    "cids": "^1.0.2",
    "ipfs": "^0.56.1",
    "ipfs-http-client": "^51.0.1",
    "truffle": "^5.4.3"
  },
  "directories": {
    "doc": "docs"
  },
  "keywords": [
    "organigram",
    "solidity",
    "governance",
    "organisations",
    "ethereum",
    "dapp"
  ],
  "bugs": {
    "url": "https://github.com/organigram/contracts/issues"
  },
  "homepage": "https://github.com/organigram/contracts#readme"
}
